{
    "name": "truyen-ktts",
    "version": "4.0.0",
    "private": true,
    "workspaces": [
        "server",
        "client"
    ],
    "scripts": {
        "server": "npm run dev --workspace=server",
        "client": "npm run dev --workspace=client",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "build": "npm run build --workspace=client",
        "postinstall": "patch-package"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.21",
        "concurrently": "^8.2.2",
        "patch-package": "^8.0.1"
    }
}